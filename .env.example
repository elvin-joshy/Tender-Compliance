PORT=5000
MONGO_URI=mongodb://localhost:27017/tender_system
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# LLM provider configuration (groq|openai|local|auto)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional OpenAI extraction/embedding settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding provider (auto|openai|local)
# auto uses OpenAI embeddings only when OPENAI_API_KEY is set; otherwise local
EMBEDDING_PROVIDER=local

# Analysis upload/input limits
ANALYSIS_MAX_UPLOAD_MB=20
ANALYSIS_MAX_TEXT_BYTES=20971520
